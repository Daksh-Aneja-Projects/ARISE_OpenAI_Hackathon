# ==========================================
# ARISE - Environment Variables Configuration
# ==========================================

# --- App Settings ---
APP_NAME="ARISE — Autonomous RFP Intelligence and Sales Engine"
APP_ENV="development"
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"

# --- Auth Configuration ---
JWT_SECRET="your_super_secret_jwt_key_here"
JWT_ALGORITHM="HS256"
JWT_EXPIRY_HOURS="24"

# --- Database & Storage ---
DATABASE_URL="sqlite+aiosqlite:///./arise.db"
UPLOAD_DIR="../knowledge_base"
MAX_UPLOAD_SIZE_MB="100"

# --- Celery & Redis (Optional - for horizontal scaling) ---
CELERY_BROKER_URL="memory://"
CELERY_RESULT_BACKEND="cache+memory://"
# For production:
# CELERY_BROKER_URL="redis://localhost:6379/0"
# CELERY_RESULT_BACKEND="redis://localhost:6379/0"

# --- pgvector (Optional - persistent RAG) ---
PGVECTOR_URL=""

# --- LLM Provider (OpenAI) ---
OPENAI_API_KEY=""
LLM_MODEL="gpt-4o"
LLM_FAST_MODEL="gpt-4o-mini"

# --- Rate Cards (Default Hourly Rates USD) ---
# Override via .env or KB rate card upload
DEFAULT_RATE_ONSHORE_USD="120"
DEFAULT_RATE_NEARSHORE_USD="90"
DEFAULT_RATE_OFFSHORE_USD="30"

# --- Org Config ---
# Path to a JSON file with custom org tree (e.g. ../knowledge_base/org_config.json)
ORG_CONFIG_FILE=""
