# ARISE — Git line-ending normalization
# Enforce LF in the repository for cross-platform consistency.
# Developers on Windows get CRLF in working tree via autocrlf=input.

* text=auto eol=lf

# Explicitly mark binary files — never touch line endings
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.svg    binary
*.woff   binary
*.woff2  binary
*.ttf    binary
*.eot    binary
*.webp   binary
*.pdf    binary
*.xlsx   binary
*.docx   binary
*.pptx   binary

# Python
*.py     text eol=lf

# TypeScript / JavaScript
*.ts     text eol=lf
*.tsx    text eol=lf
*.js     text eol=lf
*.jsx    text eol=lf
*.json   text eol=lf

# Config / CI
*.yml    text eol=lf
*.yaml   text eol=lf
*.toml   text eol=lf
*.ini    text eol=lf
*.cfg    text eol=lf
*.env    text eol=lf
*.env.example text eol=lf
Dockerfile text eol=lf
*.sh     text eol=lf

# Docs
*.md     text eol=lf
*.txt    text eol=lf
