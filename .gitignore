# ============================================================
# ARISE — Agentic RFP Intelligence & Sales Execution
# .gitignore — Security-hardened for enterprise pre-sales use
# ============================================================
# ⚠️  CRITICAL RULE: NO CLIENT DATA, NO RFPs, NO API KEYS ON GIT
# ============================================================


# ─── SECRETS & ENVIRONMENT ──────────────────────────────────
.env
.env.*
!.env.example
!**/.env.example
*.pem
*.key
*.secret
secrets/
vault/

# ─── DATABASES ──────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal

# ─── KNOWLEDGE BASE — CLIENT-SENSITIVE DATA ─────────────────
# ALL of these contain client confidential content:
# Client RFP documents — NEVER on git
knowledge_base/rfps/
# Client intelligence profiles
knowledge_base/client_profiles/
# Bid-specific analysis data
knowledge_base/bid_data/
# Generated proposals & SOWs
knowledge_base/outputs/
# Statement of Work documents
knowledge_base/sows/
# Win/loss analysis with client names
knowledge_base/win_loss_data/

# Safe KB collections (templates, company data, no client info):
# knowledge_base/brand/                — safe
# knowledge_base/clause_library/       — safe
# knowledge_base/commercial_models/    — safe
# knowledge_base/estimating_actuals/   — safe
# knowledge_base/partner_profiles/     — safe (vendor data, not clients)
# knowledge_base/rate_cards/           — safe
# knowledge_base/scope_templates/      — safe
# knowledge_base/solution_templates/   — safe
# knowledge_base/ticket_taxonomies/    — safe

# ─── AGENT OUTPUTS & MANIFESTS ──────────────────────────────
# These contain client RFP analysis, pricing, and strategy data:
backend/manifest.json
backend/agent_outputs.json
backend/all_agent_outputs.json
backend/e2e_report.json
temp.json

# ─── CLIENT DOCUMENTS & PRESENTATIONS ───────────────────────
*.pptx
*.ppt
*.xlsx
*.xls
*.docx
*.doc
*.pdf
# Allow docs folder PDFs (architecture, public docs only)
!docs/**/*.pdf

# ─── EXTRACTED / TRANSCRIBED CLIENT TEXT ────────────────────
prd_extracted.txt
skill_extracted.txt
"Friday, 17 Apr 2026 at 1_41 pm.txt"
*.txt
!README.txt               # Allow README text files
!requirements.txt
!**/requirements.txt

