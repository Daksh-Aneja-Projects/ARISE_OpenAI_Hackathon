backend/__pycache__/
backend/app/__pycache__/
backend/app/**/__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
*.pycache
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Alembic compiled migrations (keep source, not compiled)
backend/alembic/versions/__pycache__/

